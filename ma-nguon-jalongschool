			@import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@500;700;900&display=swap');
/* ===== BRAND TEXT NEON CYBERPUNK ===== */
.header-brand-text {
  font-family: 'Orbitron', sans-serif;
  font-size: 30px;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: 3.5px;
  margin-left: 18px;
  color: #eaffff;
  cursor: pointer;
  position: relative;
  transition: all 0.4s ease;

  text-shadow:
    0 0 8px rgba(0,255,255,0.8),
    0 0 18px rgba(255,0,255,0.7),
    0 0 36px rgba(0,255,255,0.6);
}

/* NEON LINE */
.header-brand-text::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: -12px;
  width: 0;
  height: 4px;
  background: linear-gradient(
    90deg,
    #00ffff,
    #ff00ff,
    #00ffff
  );
  box-shadow:
    0 0 12px rgba(0,255,255,0.9),
    0 0 24px rgba(255,0,255,0.8);
  transition: all 0.45s ease;
  transform: translateX(-50%);
}

/* HOVER CHỮ = NEON BÙNG */
.header-brand-text:hover {
  color: #ffffff;
  transform: translateY(-3px) scale(1.08);
  text-shadow:
    0 0 12px rgba(0,255,255,1),
    0 0 28px rgba(255,0,255,0.95),
    0 0 55px rgba(0,255,255,0.85);
}
.header-brand-text::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: -14px;
  width: 0;
  height: 4px;
  background: linear-gradient(90deg, #00ffff, #ff00ff, #00ffff);
  box-shadow:
    0 0 14px rgba(0,255,255,1),
    0 0 28px rgba(255,0,255,0.9);
  transition: all 0.45s ease;
  transform: translateX(-50%);
}

.header-brand-text:hover::after {
  width: 135%;
}

/* ===== LOGO NEON ===== */
.logo img {
  transition: all 0.4s ease;
  filter: drop-shadow(0 0 6px rgba(0,255,255,0.4))
          drop-shadow(0 0 14px rgba(255,0,255,0.35));
}

/* HOVER LOGO = ĐIỆN CHẠY */
.logo:hover img {
  transform: scale(1.08) rotate(-1deg);
  filter: drop-shadow(0 0 10px rgba(0,255,255,1))
          drop-shadow(0 0 22px rgba(255,0,255,0.95))
          drop-shadow(0 0 40px rgba(0,255,255,0.8));
}

/* CANH LOGO + CHỮ */
.logo {
  display: flex;
  align-items: center;
}
/* ===== HEADER NỀN TỐI – CYBERPUNK ===== */
#header,
.header-wrapper,
.header-main {
  background: linear-gradient(
    180deg,
    #0b0f1a,
    #05070d
  ) !important;
}

/* Tăng tương phản chữ menu */
.header-nav-main > li > a,
.header-nav > li > a {
  color: #eaeaea !important;
}

.header-nav-main > li > a:hover {
  color: #00ffff !important;
  text-shadow:
    0 0 6px rgba(0,255,255,0.8),
    0 0 14px rgba(255,0,255,0.6);
}
.header-main {
  box-shadow:
    inset 0 -1px 0 rgba(0,255,255,0.25),
    0 4px 20px rgba(0,0,0,0.8);
}
@media (max-width: 768px) {
  .header-brand-text {
    font-size: 22px;
    letter-spacing: 1.8px;
  }
}
/* ===== NỀN ĐEN GIỐNG USP ===== */
.dark-category-section {
  background: radial-gradient(
    circle at top,
    #1a1a1a 0%,
    #0b0b0b 45%,
    #050505 100%
  );
  padding: 80px 0;
  position: relative;
  overflow: hidden;
}

/* Hiệu ứng glow nền nhẹ */
.dark-category-section::before {
  content: "";
  position: absolute;
  inset: 0;
  background: radial-gradient(
    circle at 20% 20%,
    rgba(255,140,0,0.12),
    transparent 60%
  );
  pointer-events: none;
}

/* ===== BOX DANH MỤC ===== */
.dark-category-section .product-category {
  background: rgba(0,0,0,0.55);
  border-radius: 18px;
  padding: 25px 20px 35px;
  transition: all 0.45s ease;
  position: relative;
}

/* Ảnh danh mục */
.dark-category-section .box-image img {
  transition: all 0.45s ease;
  filter: brightness(0.95);
}

/* Tên danh mục */
.dark-category-section .box-text h4,
.dark-category-section .box-text h5 {
  color: #f5f5f5;
  font-weight: 700;
  letter-spacing: 1px;
  transition: all 0.45s ease;
}

/* ===== HOVER = GIỐNG USP ===== */
.dark-category-section .product-category:hover {
  transform: translateY(-8px);
  box-shadow:
    0 0 20px rgba(255,140,0,0.35),
    0 0 45px rgba(255,140,0,0.25);
}

.dark-category-section .product-category:hover .box-image img {
  transform: scale(1.08);
  filter:
    brightness(1.1)
    drop-shadow(0 0 18px rgba(255,140,0,0.55));
}

.dark-category-section .product-category:hover .box-text h4,
.dark-category-section .product-category:hover .box-text h5 {
  color: #ff9c2a;
  text-shadow:
    0 0 10px rgba(255,140,0,0.7),
    0 0 20px rgba(255,140,0,0.45);
}
@media (max-width: 768px) {
  .dark-category-section {
    padding: 50px 0;
  }
  .dark-category-section .product-category:hover {
    transform: translateY(-4px);
  }
}
.woocommerce-store-notice {
  background: linear-gradient(90deg, #111, #1f1f1f);
  color: #fff;
  font-weight: 600;
}

.woocommerce-store-notice a {
  color: #ff7a18;
}
/* ===== BLOG HERO ===== */
.blog-hero {
  text-align: center;
  padding: 40px 20px 25px;
  margin-bottom: 25px;
  border-bottom: 1px solid #eee;
}

.blog-hero h1 {
  font-size: 30px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-bottom: 10px;
}

.blog-hero p {
  font-size: 15px;
  color: #555;
}

.blog-hero strong {
  color: #ff7a18;
}

/* ===== POST CARD HOVER ===== */
.blog-entry-inner {
  transition: 0.35s ease;
}

.blog-entry-inner:hover {
  transform: translateY(-5px);
  box-shadow: 0 18px 40px rgba(0,0,0,0.12);
}

/* TITLE & BUTTON */
.blog-entry-title a {
  font-weight: 800;
}

.blog-entry-readmore a {
  color: #ff7a18;
  font-weight: 700;
}
.bao-cao-box {
  margin-top: 16px;
}

.btn-download {
  display: inline-block;
  margin-right: 10px;
  font-weight: 500;
  text-decoration: none;
  color: #fff;
  line-height: 1.2;
}

.btn-download.word {
  background: #2b579a;
}

.btn-download.ppt {
  background: #d24726;
}

.btn-download:hover {
  opacity: 0.85;
}
.bao-cao-box {
  margin-top: 16px;
  display: flex;
  gap: 10px;
}
.btn-download {
  display: inline-flex;        /* đổi từ inline-block */
  align-items: center;
  justify-content: center;
  width: 200px;                /* ÉP 2 nút bằng nhau */
  height: 42px;                /* chiều cao cố định */
  padding: 0;                  /* bỏ padding cũ */
  border-radius: 6px;
  font-size: 14px;
  font-weight: 500;
  text-decoration: none;
  color: #fff;
}
.footer-weather-fix {
    height: 260px;
    overflow: hidden;
}

.footer-weather-fix iframe {
    transform: scale(0.75);
    transform-origin: top center;
}

